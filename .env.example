# HomeFinance .env.example (root)
# Copy to .env and modify values as needed.
# Used by docker-compose.yml for backend service.

# JWT secret — MUST be changed in production (use a long random string)
JWT_SECRET=change-this-in-production

# Frontend URL for CORS (the address users access the app from)
CORS_ORIGIN=http://localhost

# AI Service (Volcano Engine Ark) - optional, leave empty to disable AI features
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
AI_API_KEY=
AI_MODEL=ark-code-latest
